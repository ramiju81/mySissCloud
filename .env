# mySissCloud - base local configuration
MYSISS_ENV=local
MYSISS_DB_ENGINE=sqlite

# SQLite local persistence
SQLITE_DB_PATH=./db/mysiss_local.sqlite

# Core users (do not commit real secrets)
SUPERUSER_USERNAME=ramiju
SUPERUSER_PASSWORD=CHANGE_ME_SUPERUSER
ADMIN_USERNAME=mySiss
ADMIN_PASSWORD=CHANGE_ME_ADMIN

# IRIS defaults for non-local environments
IRIS_HOST=localhost
IRIS_SUPERSERVER=1972
IRIS_NAMESPACE=CNET
